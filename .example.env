#Use this file as a template for your .env file. Copy it to .env and fill in the values.

# Database
DB_HOST=localhost
DB_USERNAME=postgres
DB_PASSWORD=postgres

# File Source Configuration
# Options: local (for local testing), smb (Windows file server), google_drive (future)
# For local testing, run: ruby script/generate_test_images.rb
FILE_SOURCE_TYPE=local
FILE_SOURCE_PATH=~/packlight_test_images

# SMB File Server (only needed if FILE_SOURCE_TYPE=smb)
SMB_HOST=\\server\items
SMB_USERNAME=your_username
SMB_PASSWORD=your_password

# Google Drive (only if FILE_SOURCE_TYPE=google_drive - not yet implemented)
# GOOGLE_DRIVE_FOLDER_ID=your_folder_id

# Email (get from SendGrid)
SENDGRID_API_KEY=SG.xxxxxx
SENDGRID_USERNAME=apikey
MAIL_FROM=noreply@yourdomain.com

# Claude API
# This is not yet implemented, but you can get an API key from Anthropic if you want to experiment with it.
#ANTHROPIC_API_KEY=sk-ant-xxxxxx

# Production (optional)
RAILS_HOST=packlight.yoursite.com
RAILS_PROTOCOL=https
