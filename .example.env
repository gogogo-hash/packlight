#Use this file as a template for your .env file. Copy it to .env and fill in the values.

# Database
DB_HOST=localhost
DB_USERNAME=postgres
DB_PASSWORD=postgres

# SMB File Server (configure for your setup)
SMB_HOST=\\server\items
SMB_USERNAME=your_username
SMB_PASSWORD=your_password

# Email (get from SendGrid)
SENDGRID_API_KEY=SG.xxxxxx
SENDGRID_USERNAME=apikey
MAIL_FROM=noreply@yourdomain.com

# Claude API
# This is not yet implemented, but you can get an API key from Anthropic if you want to experiment with it.
#ANTHROPIC_API_KEY=sk-ant-xxxxxx

# Production (optional)
RAILS_HOST=packlight.yoursite.com
RAILS_PROTOCOL=https
