<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    
    <div class="bg-white rounded-xl shadow-xl max-w-md w-full overflow-hidden transform transition-all border border-slate-200">
      
      <div class="px-6 py-4 bg-slate-50 border-b border-slate-100 flex justify-between items-center">
        <h3 class="text-lg font-bold text-slate-800">Edit Item Details</h3>
          <%= link_to "×", admin_items_path, data: { turbo_frame: "_top" }, class: "text-slate-400 hover:text-slate-600 text-2xl font-semibold leading-none" %>
     </div>

      <%= form_with(model: @item, url: admin_item_path(@item), method: :patch, data: { turbo: true }, class: "p-6 space-y-4") do |f| %>
      <div>
          <%= f.label :price, class: "block text-sm font-semibold text-slate-700 mb-1" %>
          <div class="relative rounded-md shadow-sm">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
              <span class="text-slate-500 sm:text-sm">$</span>
            </div>
            <%= f.number_field :price, step: 0.01, class: "block w-full rounded-md border-slate-300 pl-7 pr-3 py-2 text-slate-900 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm border", placeholder: "0.00" %>
          </div>
        </div>

        <div>
          <%= f.label :description, class: "block text-sm font-semibold text-slate-700 mb-1" %>
          <%= f.text_area :description, rows: 3, class: "block w-full rounded-md border-slate-300 px-3 py-2 text-slate-900 focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm border", placeholder: "Add description..." %>
        </div>

        <div class="flex justify-end space-x-3 pt-4 border-t border-slate-100 mt-6">
       <%= link_to "Cancel", admin_items_path, data: { turbo_frame: "_top" }, class: "px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-lg text-sm transition-colors" %>
          
<%= f.submit "Save Changes", class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg text-sm transition-colors cursor-pointer" %>
        </div>

      <% end %>

    </div>
  </div>
<% end %>