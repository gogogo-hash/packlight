  
  

<div class="px-2 sm:px-6 w-full">
  <div class="max-w-6xl mx-auto px-4 py-8">

    <!-- Back Link -->
    <div class="mb-2 mt-4">
      <%= link_to items_path, class: "group inline-flex items-center gap-2 text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 transition-transform group-hover:-translate-x-1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
        Back to items
      <% end %>
    </div>

    <div class="mb-2">

      <h2 class="text-2xl font-extrabold tracking-tight text-slate-900 sm:text-3xl mb-2">
        File Server Scan
      </h2>
      <p class="text-sm sm:text-base text-slate-500 max-w-2xl leading-relaxed mb-6">
        Scan your file server for new items and process them with Gemini AI.
      </p>

      <div class="flex flex-col gap-4 max-w-xs">
        <%= button_to "Connect Google Drive", 
                      admin_google_drive_connect_path,
                      method: :get,
                      data: { turbo: false }, 
                      class: "w-full bg-[#0E4450] hover:bg-[#646C5E] text-white font-semibold py-2 px-4 rounded-sm transition duration-200" %> 

          <%= form_with url: scan_admin_items_path, method: :post, local: true, class: "flex flex-col gap-4 max-w-xs" do |f| %>
          <%= hidden_field_tag :file_source_type, "google_drive" %>
          <%= hidden_field_tag :user_id, current_user.id %>

        <div class="w-full">
          <%= text_field_tag :file_source_path, nil, 
                        placeholder: "Enter Google Folder ID", 
                        class: "w-full bg-white text-slate-800 placeholder:text-slate-500 border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:outline-none p-2 rounded" %>  
        </div>

        <%= f.submit "Scan Google Drive Now", 
                class: "w-full bg-[#0E4450] hover:bg-[#646C5E] text-white font-semibold py-2 px-4 rounded-sm transition duration-200" %> 
        <% end %>

      </div>
      
    </div>

      <!-- Items Status -->
      <div class="bg-white rounded-sm shadow overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-200">
          <h3 class="text-lg font-semibold text-slate-800">Items Status</h3>
        </div>

        <% if @items.any? %>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-slate-50 border-b">
                <tr>
                  <th class="px-6 py-3 text-left text-sm font-semibold text-slate-700">File Folder Path</th>
                  <th class="px-6 py-3 text-left text-sm font-semibold text-slate-700">Status</th>
                  <th class="hidden md:table-cell px-6 py-3 text-left text-sm font-semibold text-slate-700">Last Scanned</th> 
                  <th class="px-6 py-3 text-left text-sm font-semibold text-slate-700">Price</th>
                  <th class="px-6 py-3 text-left text-sm font-semibold text-slate-700">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @items.each do |item| %>
                  <%= render "admin/items/item_row", item: item %>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="px-6 py-12 text-center text-slate-500">
            No items yet. Click "Scan File Server Now" to get started.
          </div>
        <% end %>
      </div>
  </div>
  </div>

