<div class="min-h-screen bg-slate-50">
  <!-- Navigation -->
  <nav class="bg-white shadow">
    <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
      <h1 class="text-2xl font-bold text-slate-800">
        <%= link_to "Packlight Admin", admin_items_path %>
      </h1>
      <div class="flex items-center gap-4">
        <%= link_to "Back to Items", items_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
<%= button_to "Sign Out",
    destroy_user_session_path,
    method: :delete,
    class: "text-sm text-blue-600 hover:text-blue-800 bg-transparent border-0 p-0 cursor-pointer" %>      </div>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto px-4 py-12">

    


    <div class="mb-8">
      <h2 class="text-3xl font-bold text-slate-800 mb-4">File Server Scan</h2>
      <p class="text-slate-600 mb-6">Scan your file server for new items and process them with Gemini AI.</p>

<div class="flex flex-col gap-4 max-w-xs">
  <%= button_to "Connect Google Drive", 
                user_google_oauth2_omniauth_authorize_path(
                  scope: "email,profile,https://www.googleapis.com/auth/drive.file", 
                  prompt: "consent", 
                  access_type: "offline"
                ), 
                method: :post, 
                data: { turbo: false }, 
                class: "w-full bg-green-600 text-white font-semibold py-3 px-6 rounded-lg hover:bg-green-700" %> 

  <!-- Button to trigger the picker once connected -->
<% if current_user.google_drive_token.present? %>
  <button id="picker-button" class="bg-blue-600 text-white font-semibold py-3 px-6 rounded-lg hover:bg-green-700">
    Select Target Drive Folder
  </button>
<% end %>

<script async defer src="https://apis.google.com/js/api.js"></script>

<script>
  document.addEventListener("turbo:load", function() {
    const pickerBtn = document.getElementById('picker-button');
    if (!pickerBtn) return; // Prevent errors if the button isn't rendered on the page

    const developerKey = "<%= ENV['GOOGLE_API_KEY'] %>"; 
    const appId = "<%= ENV['GOOGLE_APP_ID'] %>"; 
    const oauthToken = "<%= current_user.google_drive_token %>";

    pickerBtn.addEventListener('click', () => {
      if (typeof gapi !== 'undefined') {
        gapi.load('picker', { 'callback': createPicker });
      } else {
        alert("Google API library hasn't loaded yet. Please refresh.");
      }
    });

    function createPicker() {
      const view = new google.picker.DocsView(google.picker.ViewId.FOLDERS)
        .setSelectFolderEnabled(true)
        .setMimeTypes('application/vnd.google-apps.folder');

      const picker = new google.picker.PickerBuilder()
        .enableFeature(google.picker.Feature.NAV_HIDDEN)
        .setDeveloperKey(developerKey)
        .setAppId(appId)
        .setOAuthToken(oauthToken)
        .addView(view)
        .setCallback(pickerCallback)
        .build();

      picker.setVisible(true);
    }

    function pickerCallback(data) {
      if (data.action === google.picker.Action.PICKED) {
        const doc = data.docs[0];
        const folderId = doc.id;
        const folderName = doc.name;

        console.log(`User picked folder: ${folderName} (ID: ${folderId})`);
        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');

        fetch('/admin/items/update_google_folder', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrfToken
          },
          body: JSON.stringify({
            folder_id: folderId,
            folder_name: folderName
          })
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            alert(`Target locked! Successfully mapped folder: ${data.folder_name}`);
            window.location.reload();
          } else {
            alert(`Failed to save folder configurations: ${data.errors.join(", ")}`);
          }
        })
        .catch(error => {
          console.error("Error updating folder:", error);
          alert("An error occurred while connecting the folder to the database.");
        });

      }
    }
  });
</script>

  
  
  <%= button_to "Scan Google Drive Now",
                scan_admin_items_path,
                method: :post,
                params: { file_source_type: "google_drive", user_id: current_user.id },
                class: "w-full bg-green-600 text-white font-semibold py-3 px-6 rounded-lg hover:bg-green-700" %> 
</div>
    
    </div>

    <!-- Items Status -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-200">
        <h3 class="text-lg font-semibold text-slate-800">Items Status</h3>
      </div>

      <% if @items.any? %>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-slate-50 border-b">
              <tr>
                <th class="px-6 py-3 text-left text-sm font-semibold text-slate-700">File Folder Path</th>
                <th class="px-6 py-3 text-left text-sm font-semibold text-slate-700">Status</th>
                <th class="px-6 py-3 text-left text-sm font-semibold text-slate-700">Last Scanned</th>
                <th class="px-6 py-3 text-left text-sm font-semibold text-slate-700">Price</th>
              </tr>
            </thead>
            <tbody>
              <% @items.each do |item| %>
                <tr class="border-b hover:bg-slate-50">
                  <td class="px-6 py-4 text-slate-800 font-medium">
                    <%= link_to item.file_folder_path[item.file_folder_path.rindex('/')..-1], item_path(item), class: "text-blue-600 hover:text-blue-800" %>
                  </td>
                  <td class="px-6 py-4">
                    <% case item.status %>
                      <% when "processed" %>
                        <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-green-100 text-green-800">Processed</span>
                      <% when "pending" %>
                        <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-yellow-100 text-yellow-800">Pending</span>
                      <% when "error" %>
                        <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-red-100 text-red-800">Error</span>
                      <% else %>
                        <span class="inline-block px-3 py-1 rounded-full text-sm font-semibold bg-slate-100 text-slate-800">Unknown</span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 text-slate-600">
                    <% if item.last_scanned_at %>
                      <%= time_ago_in_words(item.last_scanned_at) %> ago
                    <% else %>
                      Never
                    <% end %>
                  </td>
                  <td class="px-6 py-4 text-slate-800">
                    <% if item.price %>
                      $<%= number_with_precision(item.price, precision: 2) %>
                    <% else %>
                      —
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="px-6 py-12 text-center text-slate-500">
          No items yet. Click "Scan File Server Now" to get started.
        </div>
      <% end %>
    </div>
  </div>
</div>
