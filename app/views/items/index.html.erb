<div class="min-h-screen m-4">


  <!-- Main Content -->
  <div class="max-w-7xl mx-auto px-4 py-4">
    <h2 class="text-[24px] font-semibold text-slate-800 mb-8 text-center">Collections</h2>

    <% if @items.any? %>
      <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
        <% @items.each do |item| %>
          <%= link_to item_path(item), class: "group" do %>
            <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition ">
              <!-- Image -->
              <div class="w-full bg-slate-200 flex items-center justify-center overflow-hidden h-48">
                <% if item.photos.first %>
                  <img src="data:image/jpeg;base64,<%= Base64.strict_encode64(item.photos.first.image_data) %>"
                       alt="<%= item.name %>"
                       class="w-full h-full object-cover group-hover:scale-105 transition">
                <% else %>
                  <div class="text-slate-400">No image</div>
                <% end %>
              </div>

              <!-- Info -->
              <div class="p-4">
                <h3 class="text-[12px] font-semibold text-slate-800 line-clamp-2"><%= item.name %></h3>
                <p class="text-lg font-semibold text-slate-800 mt-2">$<%= number_with_precision(item.price, precision: 2) %></p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <p class="text-slate-600 text-lg">No items available yet.</p>
      </div>
    <% end %>
  </div>
</div>
