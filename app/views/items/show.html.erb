<div class="min-h-screen">


  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Back Link -->
    <div class="mb-6">
      <%= link_to items_path, class: "group inline-flex items-center gap-2 text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 transition-transform group-hover:-translate-x-1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
        Back to items
      <% end %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Gallery -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-lg shadow">
          <% if @item.photos.any? %>
            <div id="gallery" class="relative">
              <% @item.photos.each_with_index do |photo, idx| %>
                <img src="data:image/jpeg;base64,<%= Base64.strict_encode64(photo.image_data) %>"
                     alt="<%= @item.name %> - photo <%= idx + 1 %>"
                     class="w-full h-auto rounded-lg gallery-image <%= 'hidden' if idx > 0 %>"
                     data-index="<%= idx %>">
              <% end %>

              <% if @item.photos.length > 1 %>
                <!-- Navigation -->
                <button class="absolute left-4 top-1/2 -translate-y-1/2 bg-black/50 text-white p-2 rounded hover:bg-black/70"
                        onclick="document.querySelector('[data-gallery-prev]').click()">
                  ‹
                </button>
                <button class="absolute right-4 top-1/2 -translate-y-1/2 bg-black/50 text-white p-2 rounded hover:bg-black/70"
                        onclick="document.querySelector('[data-gallery-next]').click()">
                  ›
                </button>

                <!-- Thumbnails -->
                <div class="flex gap-2 p-4 bg-slate-100 overflow-x-auto">
                  <% @item.photos.each_with_index do |photo, idx| %>
                    <img src="data:image/jpeg;base64,<%= Base64.strict_encode64(photo.image_data) %>"
                         alt="Thumb <%= idx + 1 %>"
                         class="w-16 h-16 object-cover rounded cursor-pointer hover:opacity-75 transition gallery-thumb"
                         data-index="<%= idx %>"
                         onclick="showGalleryImage(<%= idx %>)">
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="w-full h-96 bg-slate-200 flex items-center justify-center rounded-lg">
              <span class="text-slate-400">No images available</span>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Sidebar -->
      <div>
        <!-- Item Info -->
        <div class="bg-white rounded-lg shadow p-6 mb-6">
          <h1 class="text-3xl font-bold text-slate-800 mb-4"><%= @item.name %></h1>
          <p class="text-4xl font-bold text-slate-800 mb-4">$<%= number_with_precision(@item.price, precision: 2) %></p>
          <p class="text-slate-600 mb-6"><%= @item.description %></p>

          <!-- TODO: Subscribe Button Implementation -->
          <div>
            <% if false %>
            <% if @subscribed %>
              <%= button_to "Unsubscribe from updates",
                    item_subscription_path(@item),
                    method: :delete,
                    class: "w-full bg-slate-300 text-slate-800 font-semibold py-2 px-4 rounded hover:bg-slate-400" %>
            <% else %>
              <%= button_to "Subscribe to comments",
                    item_subscriptions_path(@item),
                    method: :create,
                    class: "w-full bg-blue-600 text-white font-semibold py-2 px-4 rounded hover:bg-blue-700" %>
            <% end %>
            <% end %>


          </div>
        </div>
      </div>
    </div>

    <!-- Comments Section -->
    <div class="mt-12">
      <h2 class="text-2xl font-bold text-slate-800 mb-6">Comments</h2>

      <!-- Add Comment Form -->
      <div class="bg-white rounded-lg shadow p-6 mb-8">
        <%= form_with model: [@item, Comment.new], local: true do |f| %>
          <div class="mb-4">
            <%= f.label :content, "Your Comment", class: "block text-sm font-medium text-slate-700 mb-2" %>
            <%= f.text_area :content, rows: 4,
                placeholder: "Comment publicly (username stays private)",
                class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
          </div>
          <%= f.submit "Post Comment", class: "w-full bg-[#0E4450] hover:bg-[#646C5E] text-white font-semibold py-2 px-4 rounded-sm transition duration-200" %>
        <% end %>
      </div>

      <!-- Comments List -->
      <div class="space-y-4">
        <% if @comments.any? %>
          <% @comments.each do |comment| %>
            <div class="bg-white rounded-lg shadow p-6">
              <div class="flex justify-between items-start mb-2">
                <div>
                  <p class="text-sm text-slate-500"><%= time_ago_in_words(comment.created_at) %> ago</p>
                </div>
              </div>
              <p class="text-slate-700"><%= comment.content %></p>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-8 text-slate-500">
            No comments yet. Be the first to comment!
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  function showGalleryImage(index) {
    document.querySelectorAll('.gallery-image').forEach(img => img.classList.add('hidden'));
    document.querySelector(`[data-index="${index}"]`).classList.remove('hidden');
  }
</script>
